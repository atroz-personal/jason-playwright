{
    "name": "fe-woo/hacienda-integration",
    "description": "WooCommerce integration with Costa Rica's Ministerio de Hacienda electronic invoicing system",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=7.4",
        "tecnickcom/tcpdf": "^6.7",
        "dompdf/dompdf": "^2.0",
        "robrichards/xmlseclibs": "^3.1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit --colors=always"
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3"
        }
    }
}
